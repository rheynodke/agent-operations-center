{
  "name": "openclaw-dashboard",
  "version": "2.0.0",
  "description": "OpenClaw Agent Operations Center — Full-stack monitoring & management dashboard",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.cjs",
    "db:check": "node -e \"require('./server/lib/db.cjs').initDatabase().then(() => console.log('db ok'))\"",
    "migrate:multitenant": "node scripts/migrate-multitenant.cjs",
    "migrate:multitenant:dry": "node scripts/migrate-multitenant.cjs --dry-run",
    "build": "vite build",
    "build:check": "tsc -b && vite build",
    "build:widget": "cd packages/aoc-embed && npm run build",
    "dev:widget": "cd packages/aoc-embed && npm run dev",
    "preview": "vite preview",
    "start": "node server/index.cjs",
    "prod": "vite build && pm2 restart aoc-dashboard || pm2 start ecosystem.config.cjs",
    "prod:start": "vite build && pm2 start ecosystem.config.cjs",
    "prod:restart": "vite build && pm2 restart aoc-dashboard",
    "postinstall": "node -e \"try{require('fs').chmodSync(require.resolve('node-pty/prebuilds/'+process.platform+'-'+process.arch+'/spawn-helper'),0o755)}catch(e){}\"",
    "generate-token": "node -e 'import(\"crypto\").then(c=>console.log(c.randomBytes(32).toString(\"hex\")))'",
    "test": "node --test --test-timeout=60000 server/lib/*.test.cjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@stefanprobst/rehype-extract-toc": "^2.2.1",
    "@tanstack/react-query": "^5.100.9",
    "@types/dagre": "^0.7.54",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "@xyflow/react": "^12.10.2",
    "adm-zip": "^0.5.17",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dagre": "^0.8.5",
    "dotenv": "^16.5.0",
    "elkjs": "^0.11.1",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "framer-motion": "^12.38.0",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.511.0",
    "multer": "^2.1.1",
    "node-pty": "^1.0.0",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.5.1",
    "react-syntax-highlighter": "^16.1.1",
    "react-xtermjs": "^1.0.10",
    "recharts": "^3.8.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "shiki": "^1.29.2",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.2.0",
    "three": "^0.183.2",
    "ws": "^8.18.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.3",
    "@types/adm-zip": "^0.5.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/three": "^0.183.1",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "cookie-parser": "^1.4.7",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
