# AOC Dashboard Configuration
# Copy this to .env and customize. Anything left blank uses the in-code default.

# ── Server ──────────────────────────────────────────────────────────────────
PORT=18800
HOST=0.0.0.0
# Set to 1 (or "loopback"/"linklocal"/"uniquelocal"/<n>) when AOC sits behind a
# reverse proxy and you want Express to honor X-Forwarded-* headers.
TRUST_PROXY=
# CORS allow-list. "*" is fine for single-user dev; pin to your domain in prod.
CORS_ORIGINS=*
# Optional dev-only override consumed by some routes/tests.
FRONTEND_ORIGIN=

# ── Auth (JWT + legacy token) ───────────────────────────────────────────────
# JWT signing secret for dashboard user sessions + per-agent service tokens.
# REQUIRED in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
# Token TTL (e.g. 1h, 7d, 30d). Default: 7d.
JWT_EXPIRES_IN=7d
# Legacy bypass token. Skill scripts now use per-agent AOC_AGENT_TOKEN; only set
# this if you still have older scripts depending on it. Same generator as above.
DASHBOARD_TOKEN=

# ── Rate limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
# Stricter limits for /api/auth/login and /api/auth/register-invite.
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=10

# ── OpenClaw paths ──────────────────────────────────────────────────────────
# Admin's OpenClaw home. Per-user homes hang under <OPENCLAW_BASE>/users/<id>/.
OPENCLAW_HOME=/Users/you/.openclaw
# Optional override for the base directory used to compute per-user homes.
# Defaults to OPENCLAW_HOME when unset.
OPENCLAW_BASE=
# Admin's default agent workspace (only used by legacy code paths).
OPENCLAW_WORKSPACE=
# Path to the openclaw binary (used by external/admin gateway control).
OPENCLAW_BIN=/opt/homebrew/bin/openclaw

# ── Gateway orchestrator (per-user gateways) ────────────────────────────────
# Hard cap on concurrently running per-user gateways on this AOC instance.
AOC_MAX_GATEWAYS=50
# Comma-separated retry delays (ms) when a per-user gateway fails to spawn.
GATEWAY_BACKOFF_MS=5000,30000,300000
# Admin's external gateway (systemd-managed) — only override if you run the
# admin gateway on a non-default port/token. Per-user gateways ignore these.
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_TOKEN=

# ── Persistence ─────────────────────────────────────────────────────────────
# Where SQLite (aoc.db) lives. Defaults to <repo>/data.
AOC_DATA_DIR=
# Automated SQLite backups.
AOC_BACKUP_ENABLED=1
AOC_BACKUP_DIR=
AOC_BACKUP_INTERVAL_MS=3600000
AOC_BACKUP_RETENTION=24

# ── WebSocket event registry ────────────────────────────────────────────────
# 1 = throw on unknown WS event types (default), 0 = log-only (dev migration).
AOC_WS_STRICT=1

# ── AI Assist ───────────────────────────────────────────────────────────────
# Uses Claude Code CLI — no separate API key needed.
CLAUDE_BIN=/opt/homebrew/bin/claude
AI_ASSIST_MODEL=haiku

# ── Built-in skill binaries (optional overrides) ────────────────────────────
# aoc-odoo skill: path to the odoocli binary if not on PATH or in a venv.
AOC_ODOOCLI_BIN=
# BigQuery / gcloud skills.
BQ_BIN=
GCLOUD_BIN=
# browser-harness skill: explicit Chromium/Chrome binary for Playwright.
AOC_CHROME_PATH=

# ── Output directories for ADLC role agents (optional) ──────────────────────
PRD_OUTPUT_DIR=
UIUX_OUTPUT_DIR=
UIUX_ODOO_OUTPUT_DIR=

# ── Google Workspace connections (optional) ─────────────────────────────────
# Required to enable the "google_workspace" connection type.
# Register an OAuth client at https://console.cloud.google.com/apis/credentials
# with redirect URI set to ${PUBLIC_URL}/api/connections/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional explicit override; otherwise derived from PUBLIC_URL.
GOOGLE_OAUTH_REDIRECT_URI=
# Optional: secret for signing OAuth state JWTs (falls back to JWT_SECRET / DASHBOARD_TOKEN).
GOOGLE_OAUTH_STATE_SECRET=
# Public URL of this AOC instance (used as the OAuth redirect base).
# Example: https://agents.dke.dev
PUBLIC_URL=

# ── Composio (optional) ─────────────────────────────────────────────────────
# Override the Composio API base for self-hosted or staging environments.
COMPOSIO_BASE_URL=

# ── Self-Learning / Satisfaction (Phase 1) ──────────────────────────────────
# LLM provider used for reflection at session_end. MVP: 'claude-code'
# (subprocess via $CLAUDE_BIN). Future: 'anthropic-api' or 'openai-compatible'.
REFLECTION_LLM_PROVIDER=claude-code
# Model alias passed to provider. Pin to Haiku for predictable cost.
REFLECTION_LLM_MODEL=claude-haiku-4-5
# Max parallel reflection LLM calls.
REFLECTION_CONCURRENCY=3
# Max queued reflections before backpressure (oldest dropped if exceeded).
REFLECTION_QUEUE_MAX=50
# LLM call timeout (ms).
REFLECTION_TIMEOUT_MS=60000
# Background rollup interval (ms) — daily metrics aggregation cadence.
SATISFACTION_ROLLUP_INTERVAL_MS=3600000
