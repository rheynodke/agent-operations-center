# OpenClaw Dashboard Configuration
# Copy this to .env and customize

# Server
PORT=18800
HOST=0.0.0.0

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DASHBOARD_TOKEN=

# OpenClaw paths
OPENCLAW_HOME=/root/.openclaw
OPENCLAW_WORKSPACE=/root/.openclaw/workspace

# Security
CORS_ORIGINS=*
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# AI Assist (uses Claude Code CLI — no separate API key needed)
CLAUDE_BIN=/opt/homebrew/bin/claude
AI_ASSIST_MODEL=haiku

# ── Google Workspace Connections (optional) ─────────────────────────────────
# Required to enable the "google_workspace" connection type in AOC.
# Register an OAuth client at https://console.cloud.google.com/apis/credentials
# with redirect URI set to ${PUBLIC_URL}/api/connections/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Public URL of this AOC instance (used as the OAuth redirect base).
# Example: https://agents.dke.dev
PUBLIC_URL=
# Optional: secret for signing OAuth state JWTs (falls back to DASHBOARD_TOKEN).
GOOGLE_OAUTH_STATE_SECRET=
